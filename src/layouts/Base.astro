---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

// Astro.site is set in astro.config.mjs (https://simonvanlierde.github.io).
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("og.png", Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Icons / theme -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0f766e" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0e1416" media="(prefers-color-scheme: dark)" />
    <meta name="color-scheme" content="light dark" />

    <!-- Apply saved theme before paint to avoid a flash -->
    <script is:inline>
      const t = localStorage.getItem("theme");
      if (t) document.documentElement.dataset.theme = t;
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />

    <script is:inline>
      const btn = document.querySelector(".theme-toggle");
      const media = matchMedia("(prefers-color-scheme: dark)");

      const isDark = () =>
        document.documentElement.dataset.theme
          ? document.documentElement.dataset.theme === "dark"
          : media.matches;

      // Icons swap via CSS keyed on aria-pressed.
      const sync = () => btn.setAttribute("aria-pressed", String(isDark()));

      btn.addEventListener("click", () => {
        const next = isDark() ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("theme", next);
        sync();
      });

      // Follow system changes only while the user hasn't picked a theme.
      media.addEventListener("change", () => {
        if (!localStorage.getItem("theme")) sync();
      });

      sync();
    </script>
  </body>
</html>
