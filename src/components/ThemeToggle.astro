{/* The button only. Its behaviour (click handler, aria-pressed, theme-color
    sync) lives in Base.astro, which looks this up by class and tolerates its
    absence. Its styles are global, in global.css. */}

<button type="button" class="theme-toggle" aria-label="Toggle dark mode" aria-pressed="false">
  <svg
    class="theme-toggle__moon"
    viewBox="0 0 24 24"
    width="18"
    height="18"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8Z"></path>
  </svg>
  <svg
    class="theme-toggle__sun"
    viewBox="0 0 24 24"
    width="18"
    height="18"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
    ></path>
  </svg>
</button>
