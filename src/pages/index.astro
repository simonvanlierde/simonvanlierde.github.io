---
import { getCollection } from "astro:content";
import DisassemblyChart from "../components/DisassemblyChart.tsx";
import ProjectCard from "../components/ProjectCard.astro";
import stats from "../data/stats.json" with { type: "json" };
import Base from "../layouts/Base.astro";

// `stats.json` is refreshed from the RELab /stats endpoint by a scheduled
// workflow (scripts/fetch-stats.mjs). Until that lands it holds seeded sample
// figures, flagged via `sample` so the chart can label them as such.
const { sample: statsAreSample = false, ...statsData } = stats;

const allProjects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
const workProjects = allProjects.filter((p) => p.data.category === "work");
const personalProjects = allProjects.filter((p) => p.data.category === "personal");

const name = "Simon van Lierde";
const tagline =
  "PhD researcher and research software engineer at CML, Leiden University. I build open, reproducible research infrastructure for industrial ecology and the circular economy.";

// Primary links, shown in the hero. Icons are inline single-colour SVGs
// (brand marks from simple-icons; the Leiden profile uses a mortarboard),
// injected with set:html and drawn in currentColor.
const icons = {
  github:
    '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>',
  linkedin:
    '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>',
  orcid:
    '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 0 1-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-4.097-3.722h-2.222z"/></svg>',
  leiden:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/><path d="M22 10v6"/><path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"/></svg>',
};

const links = [
  {
    label: "GitHub",
    href: "https://github.com/simonvanlierde",
    icon: icons.github,
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/simon-van-lierde/",
    icon: icons.linkedin,
  },
  {
    label: "ORCID",
    href: "https://orcid.org/0009-0006-6953-909X",
    icon: icons.orcid,
  },
  {
    label: "Leiden profile",
    href: "https://www.universiteitleiden.nl/en/staffmembers/simon-van-lierde",
    icon: icons.leiden,
  },
];

// Merged fixes sent back to tools I build on. Hardcoded like `links` above;
const contributions = [
  {
    ref: "fastapi-mail#283",
    href: "https://github.com/sabuhish/fastapi-mail/pull/283",
    label: "fastapi-mail pull request 283",
  },
  {
    ref: "sentier_data_tools#2",
    href: "https://github.com/sentier-dev/sentier_data_tools/pull/2",
    label: "sentier_data_tools pull request 2",
  },
];
---

<Base
  title={`${name} | PhD researcher & Research Software Engineer`}
  description={tagline}
>
  <header class="container hero">
    <h1>{name}</h1>
    <p class="hero__tagline prose">{tagline}</p>
    <p class="hero__meta prose">
      Focus areas: industrial ecology, circular economy, and life-cycle
      assessment. <br />
      Main stack: Python, FastAPI, TypeScript/React, PostgreSQL, and Docker.
    </p>
    <ul class="link-list hero__links">
      {
        links.map((l) => (
          <li>
            <a href={l.href}>
              <span
                class="link-list__icon"
                aria-hidden="true"
                set:html={l.icon}
              />
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>
  </header>

  <main id="main">
    <section class="container" aria-labelledby="work-heading">
      <h2 id="work-heading">Selected work</h2>
      <div class="card-grid">
        <!-- Featured: RELab, spanning the row, with the interactive chart -->
        <article class="card card--wide relab-card">
          <h3>Reverse Engineering Lab (RELab)</h3>
          <div class="relab-card__body">
            <div class="relab-card__intro">
              <div class="prose">
                <p>
                  Research infrastructure I designed and built: a FastAPI
                  backend, a PostgreSQL data model for life-cycle assessment,
                  and an Expo / React Native frontend. RELab collects
                  disassembly data on durable goods to close a long-standing
                  product-data gap in industrial ecology.
                </p>
                <p>
                  In active use at CML: every teardown adds components,
                  materials, and photos to an open catalogue, with Repair Cafe
                  pilots planned.
                </p>
              </div>
              <ul class="link-list">
                <li><a href="https://app.cml-relab.org">Live platform</a></li>
                <li><a href="https://docs.cml-relab.org">Documentation</a></li>
                <li>
                  <a href="https://github.com/CMLPlatform/relab">Source</a>
                </li>
                <li>
                  <a href="https://github.com/CMLPlatform/relab-rpi-cam-plugin">
                    RPI camera plugin
                  </a>
                </li>
              </ul>
            </div>

            <div class="relab__chart">
              <h4>Disassembly over time</h4>
              <p class="viz__caption">
                Activity in RELab by month. Switch measures and hover a column
                for the exact figure.{
                  statsAreSample
                    ? " The numbers shown are sample data pending a live connection to the RELab API."
                    : ""
                }
              </p>
              <DisassemblyChart
                stats={statsData}
                isSample={statsAreSample}
                client:visible
              />
            </div>
          </div>
        </article>

        {
          workProjects.map((p) => (
            <ProjectCard
              title={p.data.title}
              description={p.data.description}
              repo={p.data.repo}
              demo={p.data.demo}
              tags={p.data.tags}
              links={p.data.links}
            />
          ))
        }
      </div>

      <details class="disclosure personal" open>
        <summary>
          <h3>Personal projects ({personalProjects.length})</h3>
        </summary>
        <div class="card-grid card-grid--dense">
          {
            personalProjects.map((p) => (
              <ProjectCard
                title={p.data.title}
                description={p.data.description}
                repo={p.data.repo}
                demo={p.data.demo}
                tags={p.data.tags}
                links={p.data.links}
              />
            ))
          }
        </div>
      </details>

      <details class="disclosure">
        <summary>
          <h3>Upstream fixes ({contributions.length})</h3>
        </summary>
        <p class="prose upstream__lead">
          Small fixes I send back to tools I build on, mostly in the FastAPI and
          open-LCA ecosystems.
        </p>
        <ul class="upstream" aria-label="Merged upstream pull requests">
          {
            contributions.map((c) => (
              <li class="upstream__item">
                <a href={c.href} aria-label={c.label}>
                  {c.ref}
                </a>
              </li>
            ))
          }
        </ul>
      </details>
      
    </section>
  </main>

  <footer class="container site-footer">
    <p>
      &copy; {new Date().getFullYear()}
      {name}. Source on <a
        href="https://github.com/simonvanlierde/simonvanlierde.github.io"
        >GitHub</a
      >.
    </p>
    <button
      type="button"
      class="theme-toggle"
      aria-label="Toggle dark mode"
      aria-pressed="false"
    >
      <svg
        class="theme-toggle__moon"
        viewBox="0 0 24 24"
        width="18"
        height="18"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8Z"></path>
      </svg>
      <svg
        class="theme-toggle__sun"
        viewBox="0 0 24 24"
        width="18"
        height="18"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="4"></circle>
        <path
          d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
        ></path>
      </svg>
    </button>
  </footer>
</Base>

<style>
  .hero {
    padding-block: var(--space-2xl) var(--space-s);
  }

  /* Tagline and meta share one rem-based measure so they wrap to the same
     width (a ch-based measure makes the smaller meta text look under-set). */
  .hero__tagline,
  .hero__meta {
    max-width: 56rem;
  }

  .hero__tagline {
    margin-top: var(--space-m);
    font-size: var(--step-1);
    color: var(--text);
  }

  .hero__meta {
    margin-top: var(--space-m);
    color: var(--text-muted);
  }

  .hero__links {
    margin-top: var(--space-l);
  }

  /* Even spacing between stacked blocks inside the cards. */
  .relab-card > * + *,
  .relab-card__intro > * + *,
  .relab-card__body > * + * {
    margin-top: var(--space-m);
  }

  /* Disclosure: a collapsed <details> that keeps secondary content (personal
     projects, upstream fixes) below the work above. Native, no JS. */
  .disclosure {
    margin-top: var(--space-xl);
  }

  .disclosure summary {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    cursor: pointer;
    list-style: none; /* drop the default disclosure triangle */
    color: var(--text-muted);
  }

  .disclosure summary::-webkit-details-marker {
    display: none; /* Safari */
  }

  /* A small caret that points right when closed, down when open. */
  .disclosure summary::before {
    content: "";
    width: 0.45em;
    height: 0.45em;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(-45deg);
    transition: transform 0.15s ease;
  }

  .disclosure[open] summary::before {
    transform: rotate(45deg);
  }

  .disclosure summary h3 {
    color: inherit;
  }

  @media (prefers-reduced-motion: reduce) {
    .disclosure summary::before {
      transition: none;
    }
  }

  /* Featured card: intro and chart sit side by side once there is room. */
  @media (min-width: 48rem) {
    .relab-card__body {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: var(--space-l);
      align-items: start;
    }

    .relab-card__body > * + * {
      margin-top: 0; /* the grid gap handles spacing now */
    }
  }

  .viz__caption {
    margin-top: var(--space-xs);
    margin-bottom: var(--space-l);
    color: var(--text-muted);
  }

  .site-footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-s);
    padding-block: var(--space-l);
    border-top: var(--border-width) solid var(--border);
    font-size: var(--step--1);
    color: var(--text-muted);
  }

  .site-footer a {
    color: inherit;
  }

  /* Upstream fixes: each merged PR is rendered as the GitHub reference it is
     (repo#nnn, mono) with a leading diff-addition "+" in the accent, echoing
     what a merged patch looks like. A coda to the work, kept deliberately
     compact so it does not compete with the project cards above. */
  .upstream__lead {
    margin-top: var(--space-s);
    color: var(--text-muted);
  }

  .upstream {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-l);
    margin-top: var(--space-m);
    list-style: none;
  }

  .upstream__item a {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4em;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--text);
    text-decoration: none;
  }

  .upstream__item a::before {
    content: "+";
    font-weight: 700;
    color: var(--accent);
  }

  .upstream__item a:hover {
    color: var(--accent-strong);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }
</style>
